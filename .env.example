# Steam Web API 키 (필수)
# https://steamcommunity.com/dev/apikey 에서 발급
STEAM_API_KEY=your_api_key_here

# Steam ID (선택, 기본값으로 사용 시)
STEAM_ID=your_steam_id_here

# servers.json 전체 경로 (선택. 미설정 시 process.cwd()/servers.json 사용. Cursor MCP 사용 시 절대경로 권장)
# STEAM_MCP_SERVERS_PATH=E:/AI 관련/my_MCP/steam_mcp/servers.json

# Inventory add/remove 권한 (add_server, remove_server 호출 시 필수)
# STEAM_MCP_ADMIN_TOKEN=your_admin_token_here

# RCON 비밀번호 (각 서버의 passwordEnv에 지정) - 예시
# SERVER_RCON_PASSWORD=your_rcon_password
